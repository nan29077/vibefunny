# ===========================================================================
# VIBEACTION 환경변수 예시
# ---------------------------------------------------------------------------
# 로컬 모드(기본): 아래 값이 없어도 즉시 실행됩니다.
#   DATA_DRIVER=local  ->  /data/db.json 파일 기반 데이터 스토어 + Mock Auth
# ---------------------------------------------------------------------------

# 데이터 드라이버: local | supabase  (현재 MVP는 local 구현)
DATA_DRIVER=local

# 세션 쿠키 서명용 시크릿 (운영 시 반드시 변경)
SESSION_SECRET=change-me-in-production

# 결제 프로바이더: mock | toss  (현재 MVP는 mock 구현)
PAYMENT_PROVIDER=mock

